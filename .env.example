# Salin file ini ke .env lalu isi nilai sesuai lingkungan Anda
# cp .env.example .env

# PostgreSQL — contoh port 5433 jika DB berjalan di Docker
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/smart_clinic_pos?schema=public"

# JWT — gunakan string acak yang kuat di production
JWT_SECRET="ganti-dengan-secret-acak-yang-panjang"
JWT_EXPIRES_IN="1d"

# Midtrans Sandbox — daftar di https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxx"
MIDTRANS_IS_PRODUCTION=false

# Port HTTP server
PORT=3000
